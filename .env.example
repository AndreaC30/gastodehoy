# Copia este archivo a .env. En desarrollo local puedes dejar casi todo por defecto.
#
# --- Entorno ---
# development (por defecto): APP_SECRET débil permitido si COOKIE_SECURE=false.
# production: exige APP_SECRET fuerte (≥32 chars, no el default) al arrancar.
# ENV=development

# --- Base de datos (SQLite, archivo único en ./data/) ---
# Por defecto la app usa ./data/gastodehoy.db (relativo al cwd).
# En Docker, el contenedor monta ./data en /app/data y usa una ruta absoluta
# por entorno (ver docker-compose.yml). En desarrollo local no hace falta
# tocar nada.
# DATABASE_URL=sqlite:///./data/gastodehoy.db

TIMEZONE=Europe/Madrid

# --- Sesiones ---
# OBLIGATORIO en producción: genera uno con `openssl rand -hex 32`.
# Si COOKIE_SECURE=true y APP_SECRET sigue siendo el default, la app NO arranca.
APP_SECRET=change-me-in-prod
SESSION_TTL_DAYS=30

# Solo en producción detrás de HTTPS; déjalo en false para uvicorn local.
COOKIE_SECURE=false

# Orígenes del front (Vite u otro), separados por coma. En prod pon tu URL pública.
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Solo true detrás de un proxy que inyecte bien X-Forwarded-For (p. ej. Caddy).
# En dev / uvicorn directo déjalo en false para que el rate-limit use la IP real del socket.
# TRUST_FORWARDED_FOR=false

# --- Producción con compose.prod.yml + Caddy ---
# SITE_DOMAIN=gastos.tudominio.com
# (también inyecta canonical, og:url y sitemap.xml en el build del frontend)
# ACME_EMAIL=tu-email@ejemplo.com

# npm run dev (Vite) reenvía /api aquí. Por defecto :8000; si tienes otro servicio
# en :8000, apunta al puerto real de uvicorn, p. ej.:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# --- Recuperación de contraseña por correo (opcional) ---
# Sin SMTP_HOST la ruta POST /api/auth/forgot-password responde 503.
# Con Docker: estas variables deben estar en .env; docker-compose.yml las pasa al contenedor.
# Ejemplo Gmail/SendGrid: puerto 587, SMTP_USE_TLS=true, SMTP_USE_SSL=false.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# --- Web Push (PWA notifications — opcional) ---
# Genera claves: npx web-push generate-vapid-keys
# Sin estas variables, el push queda desactivado (web_push_enabled() = False).
# Las claves son en Base64 URL-safe, ej: BIX1c...-h7 (public) y Xh2k3...-Q (private).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gastodehoy.local
# Cron en el servidor (ej. 9:00): python -m app.cli.send_daily_push
