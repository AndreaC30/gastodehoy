# Copia este archivo a .env. Con Postgres en Docker hace falta tener la base en marcha:
#   docker compose up -d db
DATABASE_URL=postgresql+psycopg2://gastodehoy:gastodehoy@localhost:5432/gastodehoy
TIMEZONE=Europe/Madrid

# Clave para firmar la cookie de sesión. Cambia este valor antes de producción.
# Si lo cambias, todas las sesiones existentes caducan (cada cuenta vuelve a iniciar sesión).
APP_SECRET=change-me-in-prod
SESSION_TTL_DAYS=30

# Solo en producción detrás de HTTPS; déjalo en false para uvicorn local.
COOKIE_SECURE=false

# Producción con compose.prod.yml + Caddy:
# SITE_DOMAIN=gastos.tudominio.com
# ACME_EMAIL=tu-email@ejemplo.com

# npm run dev (Vite) reenvía /api aquí. Por defecto :8000; si tienes otro servicio
# en :8000, apunta al puerto real de uvicorn, p. ej.:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001
