# Opcional. Puedes poner VITE_API_PROXY_TARGET aquí o en el .env de la raíz del repo.
# Si uvicorn no escucha en 8000 (p. ej. estás en 8001), descomenta:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Opcional: otro correo de contacto en el pie (por defecto gastodehoy@gmail.com).
# VITE_CONTACT_EMAIL=otro@ejemplo.com

# Solo desarrollo: simula el día 1 del mes para probar la pregunta de ingreso.
# VITE_DEV_FORCE_INCOME_CHECK=true
